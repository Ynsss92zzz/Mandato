{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",

  "regions": ["cdg1"],

  "crons": [
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sequences",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reset-leads",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 * * * *"
    }
  ],

  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
